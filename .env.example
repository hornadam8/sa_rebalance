# Seeking Alpha — paste your full Cookie header value from a logged-in browser request.
# Used as bootstrap value; subsequent runs prefer SA_COOKIE_PATH file (which we update with
# rotated session cookies after each call).
SA_COOKIE=

# Optional: persistent cookie store. App writes rotated cookies here after each SA call,
# extending session life indefinitely while user_remember_token is valid. Roam across
# machines via iCloud Drive or similar.
# SA_COOKIE_PATH=~/Library/Mobile Documents/com~apple~CloudDocs/sa_rebalance/sa_cookie.txt

# Schwab developer app credentials (https://developer.schwab.com)
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://127.0.0.1
# Optional: location of Schwab tokens.json. Default is ~/.config/sa_rebalance/tokens.json.
# Set this to an iCloud Drive (or Dropbox) path to roam tokens across machines.
# TOKENS_PATH=~/Library/Mobile Documents/com~apple~CloudDocs/sa_rebalance/tokens.json
# Comma-separated Schwab account numbers to include in rebalancing.
# Any account not listed here is ignored.
SCHWAB_REBALANCE_ACCOUNTS=

# Gmail SMTP for run-report email. App password (not your Google account password).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=
NOTIFY_TO=you@gmail.com
